<Window x:Class="Budweg_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Budweg_WPF"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Menu" Height="720" Width="1280">
    <Grid>
        <Grid Margin="30">
            <StackPanel  Focusable="False"  Width="1210" Orientation="Vertical">
                <Label FontWeight="Bold" FontSize="100" Foreground="#FF00AC58" Margin="0" HorizontalAlignment="Center" >
                    Budweg
                </Label>
                <Label Margin="0,50,0,0" FontSize="60" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center">
                    Menu
                </Label>
                <Button Margin="0,70,0,0" Width="400" FontSize="40">
                    Opret Følgeseddel
                </Button>
                <Button x:Name="btnProduktionsOverblik" Margin="0,50,0,0" Width="400" FontSize="40" Click="BtnProduktionsOverblik_Click">
                    Produktions Overblik
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
